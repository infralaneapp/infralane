# Database (required)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/infralane

# Session (required in production, 32+ characters)
INFRALANE_SESSION_SECRET=

# Application
INFRALANE_BASE_URL=http://localhost:3000
NODE_ENV=development

# Worker mode (set to "external" when running standalone worker)
INFRALANE_WORKER_MODE=

# Automation worker manual trigger endpoint secret
AUTOMATION_WORKER_SECRET=

# Slack OAuth (optional — enables "Sign in with Slack")
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# SMTP Email (optional — enables email notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@infralane.local

# Telemetry
NEXT_TELEMETRY_DISABLED=1
