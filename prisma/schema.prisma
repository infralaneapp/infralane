generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  REQUESTER
  DEVOPS
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_FOR_REQUESTER
  RESOLVED
  CLOSED
}

enum TicketActivityType {
  CREATED
  UPDATED
  ASSIGNED
  STATUS_CHANGED
  COMMENTED
}

model User {
  id               String           @id @default(cuid())
  email            String           @unique
  passwordHash     String
  name             String
  role             UserRole         @default(REQUESTER)
  requestedTickets Ticket[]         @relation("RequestedTickets")
  assignedTickets  Ticket[]         @relation("AssignedTickets")
  comments         TicketComment[]
  activities       TicketActivity[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([role])
  @@map("users")
}

model TicketType {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  fieldSchema Json
  tickets     Ticket[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("ticket_types")
}

model Ticket {
  id           String         @id @default(cuid())
  sequence     Int            @unique @default(autoincrement())
  title        String
  description  String?        @db.Text
  status       TicketStatus   @default(OPEN)
  requesterId  String
  assigneeId   String?
  ticketTypeId String
  requester    User           @relation("RequestedTickets", fields: [requesterId], references: [id], onDelete: Restrict)
  assignee     User?          @relation("AssignedTickets", fields: [assigneeId], references: [id], onDelete: SetNull)
  ticketType   TicketType     @relation(fields: [ticketTypeId], references: [id], onDelete: Restrict)
  fields       TicketField[]
  comments     TicketComment[]
  activities   TicketActivity[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([status, createdAt(sort: Desc)])
  @@index([ticketTypeId, createdAt(sort: Desc)])
  @@index([assigneeId, status])
  @@index([requesterId, createdAt(sort: Desc)])
  @@map("tickets")
}

model TicketComment {
  id        String   @id @default(cuid())
  ticketId  String
  authorId  String
  content   String   @db.Text
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ticketId, createdAt])
  @@index([authorId])
  @@map("ticket_comments")
}

model TicketActivity {
  id        String             @id @default(cuid())
  ticketId  String
  actorId   String?
  type      TicketActivityType
  message   String
  metadata  Json?
  ticket    Ticket             @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actor     User?              @relation(fields: [actorId], references: [id], onDelete: SetNull)
  createdAt DateTime           @default(now())

  @@index([ticketId, createdAt(sort: Desc)])
  @@index([actorId])
  @@map("ticket_activities")
}

model TicketField {
  id        String   @id @default(cuid())
  ticketId  String
  key       String
  value     String   @db.Text
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ticketId, key])
  @@index([ticketId])
  @@map("ticket_fields")
}
